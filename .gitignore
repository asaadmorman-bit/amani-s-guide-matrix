# =====================================================================
# AMANI INFRASTRUCTURE MESH — CORE GITIGNORE
# =====================================================================

# 📊 Core Databases & Live Storage Vaults
# Prevents sharing your private parameter inputs, audit logs, and keys
*.db
*.db-journal
*.db-wal
*.sqlite
*.sqlite3
database/secure_mesh.db

# 📦 Dependency Management & Packaging
# Excludes heavy dependencies that are automatically built via Docker/npm install
node_modules/
/jspm_packages/
.npm
.eslintcache
.stylelintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 🛡️ Environmental Secrets & Cryptographic Keys
# Never commit your JWT_SECRET, administrative passwords, or API credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# 🚀 OS / IDE Artifacts & Virtual Platform Junk
# Keeps VMware and file manager overhead hidden from your repo
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# 🐳 Docker Logs & Temporary Assets
.dockerignore
logs
*.log
