# =========================================================================
# AMANI MATRIX USER TELEMETRY ENVIRONMENT CONFIGURATION
# Copy this file to '.env' and fill in your private developer tokens.
# =========================================================================

# Oura Ring Cloud API Token Ingress
# Source: https://cloud.ouraring.com/developers
OURA_PERSONAL_ACCESS_TOKEN=your_oura_token_here

# WHOOP Ecosystem OAuth Bearer Token Ingress
# Source: https://developer.whoop.com/
WHOOP_ACCESS_TOKEN=your_whoop_token_here

# Default Fallback Variables (Optional Overrides)
DEFAULT_PERSONA=Developer
